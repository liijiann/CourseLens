# Optional: DashScope-compatible endpoint override
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# Optional: AI request concurrency and retry tuning
AI_MAX_CONCURRENCY=10
AI_MAX_RETRIES=3
AI_RETRY_BACKOFF_BASE_SECONDS=1
AI_RATE_LIMIT_COOLDOWN_SECONDS=30
AI_CONSECUTIVE_429_THRESHOLD=2

# Auth
JWT_SECRET=your-secret-key-change-this

# CORS
ALLOWED_ORIGINS=http://localhost:3000
